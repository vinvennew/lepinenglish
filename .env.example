# 复制为 .env 后再填写；切勿把 .env 推送到仓库
# Flask 会话签名密钥（随意写一串长字符串，或运行 python -c "import secrets;print(secrets.token_hex(32))"）
SECRET_KEY=please-change-me-to-a-long-random-string

# 通义千问 / 百炼 API（OpenAI 兼容模式）
QWEN_API_KEY=

QWEN_MODEL=qwen-turbo

# 可选：Pixabay 图片搜索（免费，https://pixabay.com/api/docs/ 注册后获取）
# 未填写时，/api/word-image 会直接回退到 Wikipedia
PIXABAY_KEY=

# 可选：监听地址和端口
HOST=127.0.0.1
PORT=5000
FLASK_DEBUG=0
